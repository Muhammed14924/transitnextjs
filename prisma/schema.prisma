generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ==========================================
// 1. نظام الصلاحيات والأمان (من الفيديو)
// ==========================================
enum Role {
  ADMIN
  MANAGER
  USER
  GUEST
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  code        String   @unique
  members     User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("teams")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model OrgCompany {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]

  @@map("org_companies")
}

// ==========================================
// 2. جدول المستخدمين (الدمج بين القديم والجديد)
// ==========================================
model User {
  // التعديل هنا: تحويل ID إلى String واستخدام cuid
  id            String    @id @default(cuid())
  
  // --- الحقول الجديدة المطلوبة للوحة التحكم (Dashboard) ---
  name          String?   @db.VarChar(255)
  role          Role      @default(USER)
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  orgCompanyId  String?
  orgCompany    OrgCompany? @relation(fields: [orgCompanyId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // --- الحقول القديمة من قاعدة بياناتك ---
  username      String?   @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password      String    @db.VarChar(255)
  url           String?
  bio           String?
  joined        DateTime? @db.Timestamp(6)
  number        Int?
  address       String?
  private       Int?
  log           Int?
  last_activity DateTime? @default(now()) @db.Timestamp(6)

  // --- Relations ---
  documents     Document[]
  messages      ChatMessage[]

  @@map("users")
}

// ==========================================
// 3. الجداول اللوجستية وعمليات الشحن (الخاصة بك)
// ==========================================

model codes_tables {
  id           Int        @id
  code1        String     @db.VarChar(50)
  code2        String     @db.VarChar(50)
  code3        String     @db.VarChar(50)
  name         String     @db.VarChar(200)
  description  String     @db.VarChar(200)
  price        Int
  div_operator Int
  company      Int
  item_name    Int
  comp_items   comp_items @relation(fields: [item_name], references: [id], onDelete: Cascade, map: "codes_tables_ibfk_1")
  companies    companies  @relation(fields: [company], references: [id], onDelete: Cascade, map: "codes_tables_ibfk_2")

  @@index([company], map: "company")
  @@index([item_name], map: "item_name")
}

model comp_items {
  id               Int       @id @default(autoincrement())
  
  // -- الحقول المولدة آلياً --
  internal_code    Int       // التسلسل الداخلي (مثال: 1000001)
  item_code        Int       // ترتيب المنتج ضمن الشركة (1, 2, 3...)
  composite_code   String?   @unique @db.VarChar(50) // الكود المركب (مثال: 001-015-0005)
  
  // -- البيانات الأساسية --
  item_ar_name     String    @db.VarChar(100)
  item_en_name     String?   @db.VarChar(100)
  manufacturer_code String?   @db.VarChar(100)
  price            Decimal?  @default(0.00) @db.Decimal(10, 2)
  weight           Decimal?  @default(0) @db.Decimal(10, 2)
  package          String?   @db.VarChar(50)
  packet_weight    Decimal?  @default(0) @db.Decimal(10, 2)
  image            String?   @db.VarChar(255)
  date_exp         DateTime? @db.Date
  GTIP             Int?
  
  // -- نظام المنتجات الفرعية والرئيسية --
  ismain_item      Boolean   @default(false)
  main_item        Int?      // ID المنتج الرئيسي (يُترك فارغاً إذا كان هو الرئيسي)
  
  // -- حقول الحالة --
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // -- المفاتيح الأجنبية --
  company_name     Int       // يمثل company_id لكن احتفظنا بالاسم القديم لعدم كسر القاعدة
  item_type        Int?
  unit             Int       @default(1)

  // -- العلاقات --
  companies        companies     @relation(fields: [company_name], references: [id], onDelete: NoAction, onUpdate: NoAction)
  typeofitems      typeofitems?  @relation(fields: [item_type], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units            units         @relation(fields: [unit], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tariff_schedule  tariff_schedule? @relation(fields: [GTIP], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  parent_item      comp_items?   @relation("ItemVariants", fields: [main_item], references: [id])
  variants         comp_items[]  @relation("ItemVariants")

  codes_tables     codes_tables[]
  material_codes   material_codes[]
  invoice_items   invoice_items[]

  @@index([company_name])
  @@index([item_type])
  @@index([unit])
  @@index([main_item])
}

model companies {
  id                    Int       @id @default(autoincrement())
  company_name          String    @db.VarChar(100) // اسم الشركة بالعربي
  compen                String?   @db.VarChar(100) // اسم الشركة بالانكليزي
  place                 String?   @db.VarChar(50)  // البلد / الموقع
  
  // -- الحقول المولدة آلياً (الخوارزمية) --
  company_code          String    @unique @db.VarChar(3) // الكود الثلاثي (001)
  Sequence1             Int       // بداية تسلسل الفواتير (2600001)
  Sequence2             Int       // نهاية تسلسل الفواتير (2601000)
  first_internal_serial Int       // بداية تسلسل الأصناف الداخلي (1000000)
  
  logo                  String?   @db.VarChar(255)
  
  // -- حقول الحالة والتدقيق --
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // -- العلاقات --
  codes_tables          codes_tables[]
  comp_items            comp_items[]

  transit_shipments     transit_shipments[]
  sub_companies         sub_companies[]
  trip_sources          transport_trips[] @relation("TripSourceCompany")
  waybill_exporters     trip_waybills[] @relation("WaybillSenderCompany")
}

model sub_companies {
  id                Int       @id @default(autoincrement())
  sub_company_name  String    @db.VarChar(100)
  company_id        Int
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  shipments         transit_shipments[]
}

// model depots {
//   id          Int    @id
//   depot_name  String @db.VarChar(50)
//   depot_place String @db.VarChar(50)
//   depot_code  String @db.VarChar(3)
// }
model depots {
  id             Int       @id @default(autoincrement())
  depot_code     String    @unique @db.VarChar(3)
  depot_name     String    @db.VarChar(50)
  location       String?   @db.VarChar(100)
  manager_name   String?   @db.VarChar(50)
  contact_number String?   @db.VarChar(20)
  
  // -- حقل ربط المستودع بتاجر معين --
  traderId       Int?      // معرف التاجر التابع له المستودع
  trader         traders?  @relation(fields: [traderId], references: [id], onDelete: SetNull)
  
  // -- حقول التسلسل المالي (مولدة آلياً) --
  Sequence1      Int?      // بداية تسلسل فواتير المستودع (مثال: 2680001)
  Sequence2      Int?      // نهاية التسلسل (مثال: 2681000)
  
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trip_sources          transport_trips[] @relation("TripSourceDepot")
  trip_destinations     transport_trips[] @relation("TripDestinationDepot")

  @@index([traderId])
}

// model destination {
//   id                                       Int       @id
//   destination                              String?   @db.VarChar(50)
//   trans_2_trans_2_destinationTodestination trans_2[] @relation("trans_2_destinationTodestination")
// }
model destination {
  id               Int       @id @default(autoincrement())
  destination_name String    @db.VarChar(100) // اسم الوجهة (مطلوب)
  
  // -- الحقول اللوجستية المقترحة --
  destination_type String?   @db.VarChar(50)  // نوع الوجهة (مثال: مدينة، مستودع، تاجر، أخرى)
  
  // -- حقول الحالة والتدقيق --
  isActive         Boolean   @default(true)   // حالة الوجهة (متاحة/متوقفة)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // -- العلاقات --
  // أبقيت على العلاقة القديمة كما هي لتجنب كسر أي كود مرتبط بجدول trans_2

  trip_waybills trip_waybills[]
}

// model gates {
//   id                Int                 @id
//   gate_name         String              @db.VarChar(100)
//   transit_shipments transit_shipments[]
//   transport         transport[]
// }
// model ports {
//   id                Int                 @id(map: "ports_pk")
//   port_name         String              @db.VarChar(50)
//   transit_shipments transit_shipments[]
// }
model gates {
  id                 Int       @id @default(autoincrement())
  gate_code          String?   @unique @db.VarChar(50) // كود المعبر (اختياري)
  gate_name          String    @db.VarChar(100)
  
  // -- الحقول اللوجستية المقترحة --
  location           String?   @db.VarChar(100) // موقع المعبر (المدينة/المنطقة)
  connecting_country String?   @db.VarChar(100) // الدولة التي يربط معها المعبر (مثل: سوريا، العراق)
  
  // -- حقول الحالة والتدقيق --
  isActive           Boolean   @default(true)   // حالة المعبر (مفتوح/مغلق)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  // -- العلاقات --

  transport_trips    transport_trips[]
}

model ports {
  // لاحظ: أبقيت على @map("ports_pk") إذا كانت قاعدة بياناتك القديمة تعتمد على هذا الاسم
  id                 Int       @id(map: "ports_pk") @default(autoincrement())
  port_code          String?   @unique @db.VarChar(50) // كود الميناء العالمي (مثل TRMER)
  port_name          String    @db.VarChar(100)
  
  // -- الحقول اللوجستية المقترحة --
  city               String?   @db.VarChar(100) // المدينة التي يقع فيها الميناء
  country            String?   @db.VarChar(100) // الدولة
  
  // -- حقول الحالة والتدقيق --
  isActive           Boolean   @default(true)   // حالة الميناء (يعمل/متوقف)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  // -- العلاقات --
  loading_shipments   transit_shipments[] @relation("LoadingPort")
  discharge_shipments transit_shipments[] @relation("DischargePort")
}








model material_codes {
  id              Int        @id
  code_sys1       String     @db.VarChar(100)
  code_sys2       String     @db.VarChar(100)
  code_sys3       String     @db.VarChar(100)
  name            String     @db.VarChar(200)
  description     String     @db.VarChar(300)
  division_factor Int
  GTIP            String     @db.VarChar(12)
  comp_item       Int
  comp_items      comp_items @relation(fields: [comp_item], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "material_codes_ibfk_1")

  @@index([comp_item], map: "comp_item")
}





model tariff_schedule {
  id           Int          @id
  Customs_item String       @db.VarChar(10)
  description  String       @db.VarChar(150)
  Customs_fee  Int
  Export_fee   Int
  unit         String       @db.VarChar(10)
  comp_items   comp_items[]
}

// model traders {
//   id          Int       @id
//   trader      String?   @db.VarChar(50)
//   trader_code String    @db.VarChar(3)
//   trans_2     trans_2[]
// }
model traders {
  id              Int       @id @default(autoincrement())
  trader_code     String    @unique @db.VarChar(20) // كود يولد تلقائياً (مثل: 0001 أو TRD-0001)
  trader_name     String    @db.VarChar(100)        // اسم التاجر أو الشركة
  
  // -- الحقول اللوجستية والمالية المقترحة --
  contact_person  String?   @db.VarChar(100)        // اسم جهة الاتصال / المندوب
  phone           String?   @db.VarChar(20)         // رقم الهاتف
  email           String?   @db.VarChar(100)        // البريد الإلكتروني (لإرسال كشوفات الحساب)
  address         String?   @db.VarChar(255)        // عنوان التاجر
  tax_number      String?   @db.VarChar(50)         // الرقم الضريبي
  
  // -- حقول الحسابات (مستقبلاً) --
  opening_balance Decimal   @default(0) @db.Decimal(10, 2) // الرصيد الافتتاحي (بالموجب له، بالسالب عليه)
  credit_limit    Decimal?  @db.Decimal(10, 2)             // سقف الدين المسموح به
  
  // -- حقول النظام --
  isActive        Boolean   @default(true) // هل التاجر نشط؟
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // العلاقات المستقبلية ستكون هنا (فواتير، شحنات، دفعات)
  // shipments    shipments[]
  // invoices     invoices[]

  depots     depots[]
  trip_waybills trip_waybills[]
}



model transit_shipments {
  id                  Int       @id @default(autoincrement())
  bl_number           String    @unique @db.VarChar(50) 
  
  shipping_company    Int?      
  sender_company_id   Int?      
  port_of_loading     Int?      
  port_of_discharge   Int?      
  
  arrival_date            DateTime? @db.Date
  expected_discharge_date DateTime? @db.Date
  free_time_days          Int?      @default(14)
  
  status              String    @default("PENDING") @db.VarChar(20)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  carrier             transport_company? @relation(fields: [shipping_company], references: [id])
  sender_company      companies?         @relation(fields: [sender_company_id], references: [id])
  sub_company_id      Int?
  sub_company         sub_companies?     @relation(fields: [sub_company_id], references: [id])
  loading_port        ports?             @relation("LoadingPort", fields: [port_of_loading], references: [id])
  discharge_port      ports?             @relation("DischargePort", fields: [port_of_discharge], references: [id])
  
  documents           shipment_documents[]
  containers          shipment_containers[]
  transport_trips     transport_trips[]     @relation("TripSourceShipment")
}

model shipment_containers {
  id                         Int       @id @default(autoincrement())
  shipment_id                Int
  container_number           String    @db.VarChar(50)
  container_type             String?   @db.VarChar(20) // e.g., '20', '40', '40HC'
  weight                     Decimal?  @db.Decimal(12, 2)
  empty_return_date          DateTime? @db.Date
  customs_declaration_number String?   @db.VarChar(50) // Replaces old shipment_number
  item_count                 Int?      
  notes                      String?   @db.Text
  
  shipment                   transit_shipments @relation(fields: [shipment_id], references: [id], onDelete: Cascade)
  trip_sources               transport_trips[] @relation("TripSourceContainer")
}

model shipment_documents {
  id                  Int       @id @default(autoincrement())
  shipment_id         Int
  document_type       String    @db.VarChar(50) 
  document_number     String?   @db.VarChar(50)
  file_url            String    @db.Text        
  file_name           String    @db.VarChar(255)
  
  ai_processed        Boolean   @default(false)
  extracted_data      Json?     
  
  createdAt           DateTime  @default(now())

  shipment            transit_shipments  @relation(fields: [shipment_id], references: [id], onDelete: Cascade)
  vector_chunks       document_vectors[] 
}

model document_vectors {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id         Int?
  text                String    @db.Text
  metadata            Json?     
  embedding           Unsupported("vector(1536)") 
  
  document            shipment_documents? @relation(fields: [document_id], references: [id], onDelete: Cascade)
}



// ==========================================
// NEW: Modern Transport Architecture (Land Transport)
// ==========================================

model transport_trips {
  id                  Int       @id @default(autoincrement())
  trip_number         String?   @unique @db.VarChar(50)
  
  loading_date        DateTime? @db.Date
  driver_name         String?   @db.VarChar(100)
  driver_phone        String?   @db.VarChar(50)
  plate_front         String?   @db.VarChar(50)
  plate_back          String?   @db.VarChar(50)
  
  gate_id             Int?
  transport_company_id Int?
  sort_num            Int?
  discharge_date      DateTime? @db.Date
  
  truck_fare          Decimal?  @db.Decimal(12, 2)
  notes               String?   @db.Text
  
  status              String    @default("DISPATCHED") @db.VarChar(20)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  route_type            String?   @db.VarChar(50) // E.g., 'DIRECT_FACTORY', 'TRANSIT_PORT', 'INTERNAL_DEPOT'
  source_company_id     Int?
  source_shipment_id    Int?      // Link to the sea shipment if route_type is PORT
  source_container_id   Int?
  source_depot_id       Int?
  destination_depot_id  Int?      // Main destination for the truck

  source_company        companies?           @relation("TripSourceCompany", fields: [source_company_id], references: [id])
  source_shipment       transit_shipments?   @relation("TripSourceShipment", fields: [source_shipment_id], references: [id])
  source_container      shipment_containers? @relation("TripSourceContainer", fields: [source_container_id], references: [id])
  source_depot          depots?              @relation("TripSourceDepot", fields: [source_depot_id], references: [id])
  destination_depot     depots?              @relation("TripDestinationDepot", fields: [destination_depot_id], references: [id])

  gate                gates?               @relation(fields: [gate_id], references: [id])
  transport_company   transport_company?   @relation(fields: [transport_company_id], references: [id])
  waybills            trip_waybills[]
  documents           trip_documents[]

  @@index([gate_id])
  @@index([transport_company_id])
}

model trip_waybills {
  id                  Int       @id @default(autoincrement())
  trip_id             Int
  
  trader_id           Int?
  destination_id      Int?
  sender_company_id   Int?

  
  invoice_num         String?   @db.VarChar(50)
  receipt_num         String?   @db.VarChar(5)
  quantity            Int?      @default(0)
  weight              Decimal?  @db.Decimal(12, 2)
  
  // Invoice-specific dates (for LTL shipments)
  loading_date        DateTime? @db.Date
  discharge_date       DateTime? @db.Date
  total_invoice_items Int?      @default(0) // Total line items count
  
  allocated_fare      Decimal?  @db.Decimal(12, 2)
  notes               String?   @db.Text
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  trip                transport_trips      @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  trader              traders?            @relation(fields: [trader_id], references: [id])
  destination         destination?        @relation(fields: [destination_id], references: [id])
  sender_company      companies?          @relation("WaybillSenderCompany", fields: [sender_company_id], references: [id])
  invoice_items       invoice_items[]

  @@index([trip_id])
  @@index([trader_id])
  @@index([destination_id])
  @@index([sender_company_id])
}

// Invoice Items (Line Items for each Waybill/Invoice)
model invoice_items {
  id               Int       @id @default(autoincrement())
  waybill_id       Int       // Links to the trip_waybills (Invoice Header)
  comp_item_id     Int       // Links to comp_items (The actual product)
  unit_id          Int?      // Links to units (e.g., Box, Pallet)

  quantity         Int       @default(1)
  notes            String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  waybill          trip_waybills @relation(fields: [waybill_id], references: [id], onDelete: Cascade)
  comp_item        comp_items    @relation(fields: [comp_item_id], references: [id])
  unit             units?        @relation(fields: [unit_id], references: [id])

  @@index([waybill_id])
  @@index([comp_item_id])
  @@index([unit_id])
}

model trip_documents {
  id                  Int       @id @default(autoincrement())
  trip_id             Int
  document_type       String    @db.VarChar(50) 
  document_number     String?   @db.VarChar(50)
  file_url            String    @db.Text        
  file_name           String    @db.VarChar(255)
  
  ai_processed        Boolean   @default(false)
  
  createdAt           DateTime  @default(now())

  trip                transport_trips  @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

// model transport_company {
//   id                                                       Int         @id
//   trans_name                                               String      @db.VarChar(50)
//   transport_transport_transport_companyTotransport_company transport[] @relation("transport_transport_companyTotransport_company")
// }
model transport_company {
  id               Int       @id @default(autoincrement())
  trans_name       String    @db.VarChar(100) // اسم شركة النقل
  
  // -- الحقول اللوجستية والمالية --
  contact_person   String?   @db.VarChar(100) // اسم المندوب أو مسؤول الحركة
  phone            String?   @db.VarChar(20)  // رقم هاتف المندوب
  email            String?   @db.VarChar(100) // البريد الإلكتروني (لإرسال كشوفات الحساب)
  transport_type   String?   @db.VarChar(50)  // نطاق العمل (داخلي، دولي، ترانزيت)
  opening_balance  Decimal   @default(0) @db.Decimal(10, 2) // الرصيد الافتتاحي للشركة
  
  // -- حقول الحالة والتدقيق --
  isActive         Boolean   @default(true)   // هل نتعامل مع هذه الشركة حالياً؟
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // -- العلاقات --

  transit_shipments                                        transit_shipments[]
  transport_trips                                          transport_trips[]
}

// model typeofitems {
//   id         Int          @id
//   item_type  String       @db.VarChar(50)
//   typecode   String       @db.VarChar(3)
//   comp_items comp_items[]
// }

model typeofitems {
  id          Int          @id @default(autoincrement())
  typecode    String       @unique @db.VarChar(3) // الكود الفريد المولد آلياً
  item_type   String       @db.VarChar(100)       // اسم النوع (مثل: مشروب طاقة)
  
  // -- حقول إضافية مقترحة --
  description String?      @db.VarChar(255)       // وصف إضافي لتوضيح النوع
  isActive    Boolean      @default(true)         // هل هذا النوع متاح للاستخدام؟
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // -- العلاقات --
  comp_items  comp_items[]
}

// model units {
//   id         Int          @id
//   unit_name  String       @default("طرد") @db.VarChar(50)
//   comp_items comp_items[]
// }



model units {
  id         Int          @id @default(autoincrement())
  unit_name  String       @unique @db.VarChar(50) // جعلناها فريدة لمنع تكرار نفس الوحدة
  
  // -- حقول الحالة والتدقيق --
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // -- العلاقات --
  comp_items comp_items[]
  invoice_items invoice_items[]
}

// ==========================================
// 4. Documents & AI Chat (Phase 3)
// ==========================================
model Document {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String?
  fileSize  Int?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("pending") // pending, processed, error
  metadata  Json?    // For vector IDs or other info
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

model ChatMessage {
  id        String   @id @default(cuid())
  text      String   @db.Text
  isUser    Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("chat_messages")
}