// }

model typeofitems {
  id          Int          @id @default(autoincrement())
  typecode    String       @unique @db.VarChar(3) // الكود الفريد المولد آلياً
  item_type   String       @db.VarChar(100)       // اسم النوع (مثل: مشروب طاقة)
  
  // -- حقول إضافية مقترحة --
  description String?      @db.VarChar(255)       // وصف إضافي لتوضيح النوع
  isActive    Boolean      @default(true)         // هل هذا النوع متاح للاستخدام؟
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // -- العلاقات --
  comp_items  comp_items[]
}

